RewriteEngine On

# --- FORÇAR HTTPS & CORS ---
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Autorizar Domínios (CORS)
<IfModule mod_headers.c>
    SetEnvIf Origin "https://(www\.)?buscacnpjgratis\.com\.br" allowed_origin=$0
    SetEnvIf Origin "https://mediumspringgreen-newt-739820\.hostingersite\.com" allowed_origin=$0
    Header set Access-Control-Allow-Origin %{allowed_origin}e env=allowed_origin
    Header append Vary Origin
</IfModule>

# --- REDIRECIONAMENTO 301: Domínio antigo → Novo ---
RewriteCond %{HTTP_HOST} ^(www\.)?buscacnpj\.work$ [NC]
RewriteRule ^(.*)$ https://buscacnpjgratis.com.br/$1 [R=301,L]

# --- SEGURANÇA MÁXIMA PARA DADOS ---
# Bloqueio de acesso direto a pastas sensíveis
RewriteRule ^database/ - [F,L]
RewriteRule ^scripts/ - [F,L]
RewriteRule ^config/ - [F,L]
RewriteRule ^importador/ - [L]

# Bloqueio de download de arquivos de banco de dados
<FilesMatch "\.(db|sqlite|sql)$">
    Require all denied
</FilesMatch>

# --- Roteamento Dinâmico para CNPJs ---
# Redireciona o antigo /cnpj/1234... para /1234...
RewriteRule ^cnpj/([0-9]{14})/?$ /$1 [R=301,L]

# Servir CNPJ na raiz
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([0-9]{14})/?$ cnpj.php?cnpj=$1 [L,QSA]

# --- Roteamento Dinâmico para Rankings (Novo Modelo Hierárquico) ---
# Redireciona antigo /estado/ para /rankings/estado/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(acre|alagoas|amapa|amazonas|bahia|ceara|distrito-federal|espirito-santo|goias|maranhao|mato-grosso|mato-grosso-do-sul|minas-gerais|para|paraiba|parana|pernambuco|piaui|rio-de-janeiro|rio-grande-do-norte|rio-grande-do-sul|rondonia|roraima|santa-catarina|sao-paulo|sergipe|tocantins)/?$ /rankings/$1/ [R=301,L]

# Redireciona antigo /estado/cidade/ para /rankings/estado/cidade/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(acre|alagoas|amapa|amazonas|bahia|ceara|distrito-federal|espirito-santo|goias|maranhao|mato-grosso|mato-grosso-do-sul|minas-gerais|para|paraiba|parana|pernambuco|piaui|rio-de-janeiro|rio-grande-do-norte|rio-grande-do-sul|rondonia|roraima|santa-catarina|sao-paulo|sergipe|tocantins)/([a-z0-9-]+)/?$ /rankings/$1/$2/ [R=301,L]

# Servir Rankings na raiz
RewriteRule ^rankings/?$ rankings-index.php [L,QSA]

# Estado e Cidade sob /rankings/
RewriteRule ^rankings/([a-z-]+)/?$ ranking.php?slug=$1 [L,QSA]
RewriteRule ^rankings/([a-z-]+)/([a-z0-9-]+)/?$ cidade.php?estado_slug=$1&cidade_slug=$2 [L,QSA]

# --- URLs Limpas ---
# Redireciona de /index.html para /
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ / [L,R=301]

# Serve o arquivo .html internamente se a URL não tiver extensão
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]

DirectoryIndex index.php index.html

# --- Cache de assets estáticos ---
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
</IfModule>
